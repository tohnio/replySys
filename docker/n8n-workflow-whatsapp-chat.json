    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\n// Se a mensagem foi enviada pela própria API (bot), ignora para evitar loop\nif (body.data?.key?.fromMe === true) {\n  return [];\n}\n\n// Extrai o texto da mensagem de várias localizações possíveis\nconst text = body.data?.message?.conversation || \n             body.data?.message?.extendedTextMessage?.text || \n             body.data?.message?.imageMessage?.caption || \n             body.data?.message?.videoMessage?.caption || \n             \"\";\n\nconst remoteJid = body.data?.key?.remoteJid || \"\";\n// O remoteJid é no formato \"5551999999999@s.whatsapp.net\", extraímos apenas os números\nconst phone = remoteJid.split('@')[0];\n\nif (!phone) {\n  return [];\n}\n\nreturn {\n  user_input: text,\n  cliente_telefone: phone\n};"
      },
      "id": "db003c80-6f78-47a4-af92-a4b8b8d5d6e0",
